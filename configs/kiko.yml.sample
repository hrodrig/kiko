# kiko — configuration
# See full docs: https://github.com/hrodrig/kiko

# HTTP listen address
listen: ":8080"

# Public URL where kiko is reachable (used for tracking script URL)
public_url: "https://analytics.yourdomain.com"

# Log level: debug, info, warn, error
log_level: info

# Database (default: SQLite, zero-config)
database:
  driver: sqlite
  path: ./data/kiko.db

  # PostgreSQL example:
  # driver: postgres
  # host: localhost
  # port: 5432
  # user: kiko
  # password: ""
  # dbname: kiko
  # sslmode: disable
  # dsn: "postgres://kiko:***@localhost:5432/kiko?sslmode=disable"

  # MySQL example:
  # driver: mysql
  # host: localhost
  # port: 3306
  # user: kiko
  # password: ""
  # dbname: kiko

# In-memory hit buffer
buffer:
  # Seconds between batch flushes to the database
  flush_interval: 10
  # Max hits buffered in memory before drop (flushed periodically)
  capacity: 4096

# Rate limiting (per-IP token bucket + optional per-host ingest cap)
rate_limit:
  enabled: true
  requests_per_sec: 100
  burst: 200
  host_requests_per_sec: 50
  host_burst: 100

# Ingest filtering (Phase 3)
filter:
  # Trust X-Forwarded-For / X-Real-IP from Traefik/Ingress
  trust_proxy: true
  # Drop hits from known cloud/hosting CIDR ranges (lightweight CE-style list)
  block_datacenter_ips: false
  # Extra CIDR strings appended to the built-in datacenter list
  datacenter_cidrs: []
  # Exclude operator IPs from stats (hostname, IP, or CIDR)
  ignore_ips:
    - 203.0.113.10

# Only accept hits from these hosts (empty = accept all)
# Supports: hostnames, IPs, CIDR ranges
allowed_hosts:
  - gghstats.com
  - kzero.dev
  - hermesrodriguez.com

# Daily visitor fingerprint salt (required in production)
# Override via KIKO_VISITOR_SALT
visitor:
  salt: ""

# Stats API (Phase 2) — consumed by kui
api:
  # Set in production via KIKO_API_KEY (empty = open, dev only)
  key: ""
  rate_limit:
    enabled: true
    requests_per_sec: 30
    burst: 60
